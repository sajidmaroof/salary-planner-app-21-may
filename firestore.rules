rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A signed-in user can read & write ONLY their own document and everything
    // underneath it (e.g. the /expenses subcollection). No one can access
    // another user's data.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
  }
}
